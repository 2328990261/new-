# 复制本文件为 .env 并填写实际值（.env 不要提交到 git）

# 微信支付异步通知完整 URL（HTTPS），与商户平台配置一致；不填则使用「当前请求域名 + /api/payment/notify」
# PAYMENT_NOTIFY_URL=https://你的域名/api/payment/notify

# 数据库等已有配置...
# DB_HOST=127.0.0.1
# DB_NAME=...
# ...

# ---------- Coze 简历智能分析工作流（教师端「从简历导入」用）----------
# 在 Coze 部署页「执行工作流」→ Header「API Token」处查看/生成
COZE_RESUME_TOKEN=
# 可选，默认如下；若你改了部署域名再填
COZE_RESUME_RUN_URL=https://g4w3zctmc2.coze.site/run

# ---------- 支付宝小程序：手机号解密 ----------
# 对应环境变量（请从支付宝开放平台复制“接口内容加密方式-查看-字符串”）
# 注意：此处不要提交真实密钥到 git
ALIPAY_PHONE_AES_KEY=

# 可选：如你后续要开启验签，把公钥配置上
# ALIPAY_PHONE_ALIPAY_PUBLIC_KEY=
# ALIPAY_PHONE_VERIFY_SIGN=false
