# 本地开发环境配置
# 此文件在本地开发时自动使用（npm run dev）

# API基础路径 - 本地开发通过Vite代理访问后端
VITE_API_BASE_URL=/admin

# 后端服务地址 - 本地开发环境
VITE_BACKEND_URL=http://localhost:8000

# 应用基础路径 - 本地开发使用根路径
VITE_BASE_URL=/

# IOPaint 去水印（本地可直接打开线上或自建地址）
VITE_IOPAINT_URL=https://t.jiajiao91.com/iopaint/

# 在线图片加水印工具（外链）
VITE_WATERMARK_URL=https://file-converter-free.com/zh/image-tools/add-watermark-to-image-free

# 环境标识
VITE_APP_ENV=development
