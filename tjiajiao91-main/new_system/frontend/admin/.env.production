# 鐢熶骇鐜閰嶇疆
# 姝ゆ枃浠跺湪鐢熶骇鏋勫缓鏃惰嚜鍔ㄤ娇鐢紙npm run build锛?
# API鍩虹璺緞 - 鐢熶骇鐜鐩存帴璇锋眰鍚庣API
VITE_API_BASE_URL=/admin

# 鍚庣鏈嶅姟鍦板潃 - 鐢熶骇鐜浣跨敤鍚屽煙鍚嶏紝閫氳繃Nginx浠ｇ悊
VITE_BACKEND_URL=

# 搴旂敤鍩虹璺緞 - 瀹濆閮ㄧ讲鍦?/admin/ 瀛愯矾寰勪笅
VITE_BASE_URL=/admin/

# IOPaint 去水印（独立页面，同域子路径）
VITE_IOPAINT_URL=https://t.jiajiao91.com/iopaint/

# 在线图片加水印工具（外链）
VITE_WATERMARK_URL=https://file-converter-free.com/zh/image-tools/add-watermark-to-image-free

# 鐜鏍囪瘑
VITE_APP_ENV=production
